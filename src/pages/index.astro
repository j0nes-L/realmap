---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main class="flex h-screen w-screen items-center justify-center px-6">
        <section class="max-w-md text-center">
            <div
                class="mx-auto mb-6 flex h-14 w-14 items-center justify-center rounded-xl border-2 border-amber-400/90"
            >
                <span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>
            </div>
            <h1 class="text-2xl font-semibold text-stone-100">RealMap</h1>
            <p class="mt-3 text-sm leading-relaxed text-stone-400">
                This site is under construction and will be available soon.
            </p>
        </section>
    </main>
</Layout>
