---
import Layout from "../layouts/Layout.astro";
import MapSelector from "../components/MapSelector.tsx";
---

<Layout>
    <main class="relative h-screen w-screen overflow-hidden">
        <header
            class="pointer-events-none absolute left-1/2 top-[4.5rem] z-[5] -translate-x-1/2 rounded-full border border-white/10 bg-stone-900/70 px-4 py-1.5 text-xs text-stone-300 backdrop-blur"
        >
            Pan and zoom to frame your export area
        </header>

        <MapSelector client:only="react" />
    </main>
</Layout>
